{
  "name": "marketing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npx playwright test",
    "test:checkout": "npm run test:checkout:without-env && npm run test:checkout:with-env",
    "test:checkout:with-env": "npx playwright test tests/checkout-with-env.spec.ts",
    "test:checkout:without-env": "npx playwright test tests/checkout-without-env.spec.ts",
    "test:webhook": "npx playwright test tests/webhook.spec.ts",
    "test:webhook:no-secret": "npx playwright test tests/webhook.spec.ts -g 'fail-closed branch'"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-separator": "^1.1.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.556.0",
    "next": "^16.1.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "resend": "^6.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chrome-launcher": "^1.1.2",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "lighthouse": "^12.3.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
