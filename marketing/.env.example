# ─── Marketing App env vars ───
# Copy this file to marketing/.env.local and fill in real values.
# marketing/.env.local is gitignored (root .gitignore line 4).

# ─── Supabase (Phase 89 — MARK-06) ───
# A SEPARATE Supabase project from the existing app.
# Service-role key — SERVER-ONLY (do NOT prefix with NEXT_PUBLIC_).
MARKETING_SUPABASE_URL=
MARKETING_SUPABASE_KEY=

# Anon key — browser-safe (NEXT_PUBLIC_ prefix exposes to client bundle).
NEXT_PUBLIC_MARKETING_SUPABASE_URL=
NEXT_PUBLIC_MARKETING_SUPABASE_ANON_KEY=

# ─── Lemon Squeezy (Phase 91 — MARK-03 / MARK-04 — provisioned via M2) ───
# Server-only secrets (no NEXT_PUBLIC_ prefix — never bundled into browser).
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STARTER_VARIANT_ID=
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_CLOUD_SYNC_VARIANT_ID=

# Browser-safe (NEXT_PUBLIC_ prefix exposes to client bundle — used by pricing.tsx to build hosted-checkout URLs).
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_SLUG=
NEXT_PUBLIC_LEMON_SQUEEZY_STARTER_VARIANT_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_PRO_VARIANT_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_CLOUD_SYNC_VARIANT_ID=

# ─── Resend (Phase 91 — license-key email delivery — provisioned via M3) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── GitHub release downloads (referenced in license email body per D-14) ───
NEXT_PUBLIC_GITHUB_REPO=obsidsrl/edit-factory

# ─── OAuth signing (Phase 93 — OAUTH-02) ───
# JWT signing key for marketing-app-issued tokens.
# Generate with: openssl rand -base64 64
# OAUTH_JWT_SIGNING_KEY=
