# Edit Factory - Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ======================
# Supabase Configuration (Required)
# ======================
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ======================
# Backend API URL
# ======================
# Development
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Production (uncomment for deployment)
# NEXT_PUBLIC_API_URL=https://studio-api.blipost.com/api/v1

# Web images must compile both flags as false. Desktop distribution builds set
# NEXT_PUBLIC_DESKTOP_MODE=true in their separate build path.
NEXT_PUBLIC_DESKTOP_MODE=false
NEXT_PUBLIC_AUTH_DISABLED=false
