{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-dev/types/**/*.ts",
    ".next-dev/dev/types/**/*.ts",
    ".next-design/types/**/*.ts",
    ".next-design/dev/types/**/*.ts",
    ".next-verify/types/**/*.ts",
    ".next-verify/dev/types/**/*.ts",
    ".next-design-live/types/**/*.ts",
    ".next-design-live/dev/types/**/*.ts",
    ".next-subtitle-template-verify/types/**/*.ts",
    ".next-subtitle-template-verify/dev/types/**/*.ts",
    ".next-direct-edit/types/**/*.ts",
    ".next-direct-edit/dev/types/**/*.ts",
    ".next-attention-verify/types/**/*.ts",
    ".next-attention-verify/dev/types/**/*.ts",
    ".next-attention-step3-verify/types/**/*.ts",
    ".next-attention-step3-verify/dev/types/**/*.ts",
    ".next-design-41739/types/**/*.ts",
    ".next-design-41739/dev/types/**/*.ts",
    ".next-attention-duration-verify-2/types/**/*.ts",
    ".next-attention-duration-verify-2/dev/types/**/*.ts",
    ".next-codex-subtitle/types/**/*.ts",
    ".next-codex-subtitle/dev/types/**/*.ts",
    ".next-codex-subtitle-3108/types/**/*.ts",
    ".next-codex-subtitle-3108/dev/types/**/*.ts",
    ".next-codex-grouping/types/**/*.ts",
    ".next-codex-grouping/dev/types/**/*.ts",
    ".next-collapse-check/types/**/*.ts",
    ".next-collapse-check/dev/types/**/*.ts",
    ".next-codex-attention-rotation/types/**/*.ts",
    ".next-codex-attention-rotation/dev/types/**/*.ts",
    ".next-codex-subtitle-fix/types/**/*.ts",
    ".next-codex-subtitle-fix/dev/types/**/*.ts",
    ".next-endcap-check/types/**/*.ts",
    ".next-endcap-check/dev/types/**/*.ts",
    ".next-attention-slot-ux/types/**/*.ts",
    ".next-attention-slot-ux/dev/types/**/*.ts",
    ".next-codex-subtitle-style-delete/types/**/*.ts",
    ".next-codex-subtitle-style-delete/dev/types/**/*.ts",
    ".next-codex-source-panel/types/**/*.ts",
    ".next-codex-source-panel/dev/types/**/*.ts",
    ".next-codex-timeline/types/**/*.ts",
    ".next-codex-timeline/dev/types/**/*.ts",
    ".next-codex-timeline-turbo/types/**/*.ts",
    ".next-codex-timeline-turbo/dev/types/**/*.ts",
    ".next-sticky-preview/types/**/*.ts",
    ".next-sticky-preview/dev/types/**/*.ts",
    ".next-codex-endcap-check/types/**/*.ts",
    ".next-codex-endcap-check/dev/types/**/*.ts",
    ".next-subtitle-color-verify/types/**/*.ts",
    ".next-subtitle-color-verify/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
