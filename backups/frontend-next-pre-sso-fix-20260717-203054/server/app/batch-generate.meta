{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/batch-generate/layout,_N_T_/batch-generate/page,_N_T_/batch-generate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/batch-generate/__PAGE__",
    "/batch-generate",
    "/_index",
    "/_head"
  ]
}