{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/segments/layout,_N_T_/segments/page,_N_T_/segments"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/segments/__PAGE__",
    "/segments",
    "/_index",
    "/_head"
  ]
}