# Edit Factory - Backend Environment Variables
# Copy this file to .env and fill in your values

# ======================
# Supabase Configuration (Required)
# ======================
SUPABASE_URL=https://your-project.supabase.co
# Anon key (public key for client-side usage)
SUPABASE_KEY=your-anon-key
# Service role key: REQUIRED for backend operations.
# Allows the backend to bypass Row Level Security (RLS) and access all rows.
# Get from: Supabase Dashboard > Settings > API > Project API Keys > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret for token verification
# Get this from: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ======================
# AI Services (Required)
# ======================
GEMINI_API_KEY=your-gemini-api-key

# ElevenLabs TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_DEFAULT_USER_CREDIT_LIMIT=10000

# ======================
# CORS Configuration
# ======================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://editai.obsid.ro,https://blipstudio.blipost.com

# ======================
# Server Configuration
# ======================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Paths (adjust for your system)
# For containers, set BASE_DIR plus all four explicit directories to the same
# persistent volume root (the production compose uses /data).
# BASE_DIR=/data
INPUT_DIR=./input
OUTPUT_DIR=./output
LOGS_DIR=./logs
# MEDIA_DIR=./media

# ======================
# Optional Services
# ======================
# Redis for caching/job queue
# REDIS_URL=redis://localhost:6379/0

# Google Drive integration
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id
# GOOGLE_CREDENTIALS_PATH=./credentials/google_service_account.json

# fal.ai TTS alternative
# FAL_API_KEY=your-fal-api-key
# Used by both AI Image and AI Video (Seedance 2.0) generation.
# FAL_SEEDANCE_MODEL_ID=bytedance/seedance-2.0/text-to-video

# Postiz social media publishing
# POSTIZ_API_URL=https://app.postiz.com/api
# POSTIZ_API_KEY=your-postiz-api-key

# Authentication
# AUTH_DISABLED=true

# Blipost web bridge and credit metering (required in production web mode)
# BLIPOST_PLATFORM_BASE_URL=https://blipost.com
# Must exactly match WEB's server-only STUDIO_SERVICE_TOKEN.
# STUDIO_SERVICE_TOKEN=replace-with-a-long-random-secret

# Desktop mode (Electron app — bypasses auth, uses AppData paths)
# DESKTOP_MODE=false

# Data backend: "supabase" (default) or "sqlite"
# DATA_BACKEND=supabase

# File storage backend: "local" (default) or "supabase"
# FILE_STORAGE_BACKEND=local

# Media directory for structured file storage
# MEDIA_DIR=./media

# Output file TTL in hours (auto-cleanup of old renders)
# OUTPUT_TTL_HOURS=72

# ElevenLabs account encryption key (for multi-account management)
# ELEVENLABS_ENCRYPTION_KEY=

# FFmpeg concurrency limits (tune for your hardware)
# MAX_CONCURRENT_RENDERS=1
# MAX_CONCURRENT_PREP=2
# SEMAPHORE_ACQUIRE_TIMEOUT=600
# MIN_FREE_DISK_BYTES=2147483648

# MinIO video storage for Buffer publishing
# Kong proxies /s3/* to MinIO (anonymous public bucket)
# Do not configure a fixed-age bucket lifecycle: Buffer requires each video URL
# to remain public until its scheduled publication time. Use scripts/minio-cleanup.sh
# to remove objects based on the publication's scheduled_at timestamp.
# MINIO_PUBLIC_URL=https://supabase.nortia.ro/s3/buffer-videos

# Sentry error tracking
# SENTRY_DSN=

# Anthropic (Claude) for script generation
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=

# Local Codex provider (desktop only; uses `codex login`, never an API key)
# CODEX_MODEL=gpt-5.4-mini
# Optional if `codex` is not discoverable on PATH:
# CODEX_CLI_PATH=C:\path\to\codex.exe
# CODEX_TIMEOUT_SECONDS=180
